<Window x:Class="FinanceManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Менеджер личных финансов" Height="600" Width="900"
        Background="#F0F2F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- Шапка с показателями -->
        <Border Grid.Row="0" Background="#1A2340" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Менеджер личных финансов"
                           FontSize="22" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"/>

                <!-- Доходы -->
                <Border Grid.Column="1" Background="#2E7D32"
                        CornerRadius="8" Padding="15,8" Margin="5,0">
                    <StackPanel>
                        <TextBlock Text="Доходы" Foreground="White"
                                   FontSize="11" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalIncome, StringFormat='+ {0:N0} руб.'}"
                                   Foreground="White" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Расходы -->
                <Border Grid.Column="2" Background="#B71C1C"
                        CornerRadius="8" Padding="15,8" Margin="5,0">
                    <StackPanel>
                        <TextBlock Text="Расходы" Foreground="White"
                                   FontSize="11" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalExpense, StringFormat='- {0:N0} руб.'}"
                                   Foreground="White" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Баланс -->
                <Border Grid.Column="3" Background="#1565C0"
                        CornerRadius="8" Padding="15,8" Margin="5,0">
                    <StackPanel>
                        <TextBlock Text="Баланс" Foreground="White"
                                   FontSize="11" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Balance, StringFormat='{}{0:N0} руб.'}"
                                   Foreground="White" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Таблица транзакций -->
        <Border Grid.Row="1" Margin="10" Background="White" CornerRadius="4">
            <!-- Список берём из VM, редактирование пока не нужно -->
            <DataGrid ItemsSource="{Binding Transactions}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectedItem="{Binding SelectedTransaction}"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="#F8F9FA">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#2C3E6B"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,8"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Дата"
                        Binding="{Binding Date, StringFormat='dd.MM.yyyy'}"
                        Width="110"/>
                    <DataGridTextColumn Header="Тип"
                        Binding="{Binding TypeDisplay}"
                        Width="100"/>
                    <DataGridTextColumn Header="Категория"
                        Binding="{Binding Category}"
                        Width="150"/>
                    <DataGridTextColumn Header="Сумма"
                        Binding="{Binding Amount, StringFormat='{}{0:N0} руб.'}"
                        Width="130"/>
                    <DataGridTextColumn Header="Комментарий"
                        Binding="{Binding Comment}"
                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Кнопки управления -->
        <Border Grid.Row="2" Background="White"
                BorderThickness="0,1,0,0" BorderBrush="#E0E0E0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="10,8">
                <!-- Команды лежат в MainViewModel -->
                <Button Content="Добавить" Width="130" Height="38"
                        Margin="5,0" Background="#1565C0" Foreground="White"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                        Command="{Binding AddTransactionCommand}"/>
                <Button Content="Удалить" Width="130" Height="38"
                        Margin="5,0" Background="#757575" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding DeleteTransactionCommand}"
                        CommandParameter="{Binding SelectedTransaction}"/>
                <Button Content="Отчёты" Width="130" Height="38"
                        Margin="5,0" Background="#2E7D32" Foreground="White"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                        Command="{Binding OpenReportsCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>