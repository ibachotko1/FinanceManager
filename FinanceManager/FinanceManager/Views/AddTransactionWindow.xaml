<Window x:Class="FinanceManager.Views.AddTransactionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить транзакцию" Height="520" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Поля формы — прокручиваемые -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                      Padding="25,25,25,10">
            <StackPanel>
                <TextBlock Text="Новая транзакция" FontSize="20" FontWeight="Bold"
                           Foreground="#1A2340" Margin="0,0,0,20"/>

                <TextBlock Text="Тип" Foreground="#555" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding TransactionTypes}"
                          SelectedItem="{Binding SelectedType}"
                          Height="34" Margin="0,0,0,15" Padding="8,4"/>

                <TextBlock Text="Сумма (руб.)" Foreground="#555" Margin="0,0,0,5"/>
                <TextBox Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}"
                         Height="34" Margin="0,0,0,15" Padding="8,4"/>

                <TextBlock Text="Категория" Foreground="#555" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          Height="34" Margin="0,0,0,15" Padding="8,4"/>

                <TextBlock Text="Дата" Foreground="#555" Margin="0,0,0,5"/>
                <DatePicker SelectedDate="{Binding Date}"
                            Height="34" Margin="0,0,0,15"/>

                <TextBlock Text="Комментарий (необязательно)"
                           Foreground="#555" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Comment}" Height="60" Margin="0,0,0,10"
                         Padding="8,4" TextWrapping="Wrap" AcceptsReturn="True"/>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="Red" Margin="0,0,0,5"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки — всегда видны внизу -->
        <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"
                Background="White" Padding="25,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Width="120" Height="38" Margin="0,0,10,0"
                        Background="#757575" Foreground="White" BorderThickness="0"
                        Command="{Binding CancelCommand}"/>
                <Button Content="Сохранить" Width="120" Height="38"
                        Background="#1565C0" Foreground="White" FontWeight="Bold"
                        BorderThickness="0"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
