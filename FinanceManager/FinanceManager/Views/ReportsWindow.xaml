<Window x:Class="FinanceManager.Views.ReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:FinanceManager.Views"
        Title="Отчёты и аналитика" Height="650" Width="900"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#1A2340" Padding="20,10">
            <Grid>
                <TextBlock Text="Отчёты и аналитика" FontSize="20"
                           FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"/>
                <Button Content="Обновить" HorizontalAlignment="Right"
                        Width="120" Height="36" Background="#37474F"
                        Foreground="White" BorderThickness="0"
                        Command="{Binding RefreshCommand}"/>
            </Grid>
        </Border>

        <!-- Период -->
        <Border Grid.Row="1" Background="White" Margin="10,8,10,0"
                CornerRadius="4" Padding="15,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Период" FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,15,0"/>
                <TextBlock Text="С:" VerticalAlignment="Center"
                           Margin="0,0,5,0"/>
                <DatePicker SelectedDate="{Binding DateFrom}" Width="130"
                            Height="30"/>
                <TextBlock Text="По:" VerticalAlignment="Center"
                           Margin="15,0,5,0"/>
                <DatePicker SelectedDate="{Binding DateTo}" Width="130"
                            Height="30"/>
                <Button Content="День" Width="80" Height="30"
                        Margin="15,0,5,0"
                        Background="#455A64" Foreground="White"
                        BorderThickness="0"
                        Command="{Binding SetDayCommand}"/>
                <Button Content="Неделя" Width="80" Height="30" Margin="5,0"
                        Background="#455A64" Foreground="White"
                        BorderThickness="0"
                        Command="{Binding SetWeekCommand}"/>
                <Button Content="Месяц" Width="80" Height="30" Margin="5,0"
                        Background="#455A64" Foreground="White"
                        BorderThickness="0"
                        Command="{Binding SetMonthCommand}"/>
                <Button Content="Период" Width="80" Height="30" Margin="5,0"
                        Background="#455A64" Foreground="White"
                        BorderThickness="0"
                        Command="{Binding RefreshCommand}"/>
            </StackPanel>
        </Border>

        <!-- Сводка -->
        <Grid Grid.Row="2" Margin="10,8,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#2E7D32" CornerRadius="8"
                    Margin="0,0,5,0" Padding="20,10">
                <StackPanel>
                    <TextBlock Text="Доходы за период" Foreground="#A5D6A7"
                               FontSize="12"/>
                    <TextBlock Text="{Binding TotalIncome, StringFormat='+{0:N0} руб.'}"
                               Foreground="White" FontSize="24"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#B71C1C" CornerRadius="8"
                    Margin="5,0" Padding="20,10">
                <StackPanel>
                    <TextBlock Text="Расходы за период" Foreground="#EF9A9A"
                               FontSize="12"/>
                    <TextBlock Text="{Binding TotalExpense, StringFormat='-{0:N0} руб.'}"
                               Foreground="White" FontSize="24"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#1565C0" CornerRadius="8"
                    Margin="5,0,0,0" Padding="20,10">
                <StackPanel>
                    <TextBlock Text="Итого за период" Foreground="#90CAF9"
                               FontSize="12"/>
                    <TextBlock Text="{Binding Total, StringFormat='{}{0:N0} руб.'}"
                               Foreground="White" FontSize="24"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Транзакции и диаграмма -->
        <Grid Grid.Row="3" Margin="10,8,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Таблица транзакций -->
            <Border Grid.Column="0" Background="White" CornerRadius="4"
                    Margin="0,0,5,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Транзакции за период" FontWeight="Bold"
                               Padding="15,10"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding FilteredTransactions}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              CanUserSortColumns="True">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#2C3E6B"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Padding" Value="8,6"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата"
                                                Binding="{Binding Date, StringFormat='dd.MM.yyyy'}"
                                                SortMemberPath="Date"
                                                Width="90"/>
                            <DataGridTextColumn Header="Тип"
                                                Binding="{Binding TypeDisplay}"
                                                SortMemberPath="Type"
                                                Width="70"/>
                            <DataGridTextColumn Header="Категория"
                                                Binding="{Binding Category}"
                                                SortMemberPath="Category"
                                                Width="110"/>
                            <DataGridTextColumn Header="Сумма"
                                                Binding="{Binding Amount, StringFormat='{}{0:N0} руб.'}"
                                                SortMemberPath="Amount"
                                                Width="100"/>
                            <DataGridTextColumn Header="Комментарий"
                                                Binding="{Binding Comment}"
                                                SortMemberPath="Comment"
                                                Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Круговая диаграмма расходов по категориям -->
            <Border Grid.Column="1" Background="White" CornerRadius="4"
                    Margin="5,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Расходы по категориям" FontWeight="Bold"
                               Padding="15,10"/>
                    <views:CategoryPieChart Grid.Row="1"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            ItemsSource="{Binding ExpensesByCategory}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
