<Window x:Class="FinanceManager.Views.ReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отчёты" Height="500" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Кнопки периода -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
            <TextBlock Text="Период:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <Button Content="День" Width="70" Margin="0,0,5,0"
                    Command="{Binding RefreshCommand}"/>
            <Button Content="Неделя" Width="70" Margin="0,0,5,0"
                    Command="{Binding SetWeekCommand}"/>
            <Button Content="Месяц" Width="70" Margin="0,0,5,0"
                    Command="{Binding SetMonthCommand}"/>
            <Button Content="Всё время" Width="80" Margin="0,0,5,0"
                    Command="{Binding SetAllCommand}"/>
        </StackPanel>

        <!-- Ручной выбор дат -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
            <TextBlock Text="С:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <DatePicker SelectedDate="{Binding DateFrom}" Width="130"/>
            <TextBlock Text="По:" VerticalAlignment="Center" Margin="10,0,5,0"/>
            <DatePicker SelectedDate="{Binding DateTo}" Width="130"/>
            <Button Content="Обновить" Width="80" Margin="10,0,0,0"
                    Command="{Binding RefreshCommand}"/>
        </StackPanel>

        <!-- Итоги -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,5">
            <TextBlock Text="Доходы:" Margin="0,0,5,0"/>
            <TextBlock Text="{Binding TotalIncome, StringFormat='{}{0:N0} руб.'}" Margin="0,0,15,0"/>
            <TextBlock Text="Расходы:" Margin="0,0,5,0"/>
            <TextBlock Text="{Binding TotalExpense, StringFormat='{}{0:N0} руб.'}" Margin="0,0,15,0"/>
            <TextBlock Text="Итого:" Margin="0,0,5,0"/>
            <TextBlock Text="{Binding Total, StringFormat='{}{0:N0} руб.'}"/>
        </StackPanel>

        <!-- Таблицы -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0" Margin="0,0,5,0"
                      ItemsSource="{Binding FilteredTransactions}"
                      AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Дата"
                                        Binding="{Binding Date, StringFormat='dd.MM.yyyy'}"
                                        Width="90"/>
                    <DataGridTextColumn Header="Тип"
                                        Binding="{Binding TypeDisplay}" Width="70"/>
                    <DataGridTextColumn Header="Категория"
                                        Binding="{Binding Category}" Width="110"/>
                    <DataGridTextColumn Header="Сумма"
                                        Binding="{Binding Amount, StringFormat='{}{0:N0} руб.'}"
                                        Width="100"/>
                    <DataGridTextColumn Header="Комментарий"
                                        Binding="{Binding Comment}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <DataGrid Grid.Column="1"
                      ItemsSource="{Binding ExpensesByCategory}"
                      AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Категория"
                                        Binding="{Binding Category}" Width="*"/>
                    <DataGridTextColumn Header="Сумма"
                                        Binding="{Binding Amount, StringFormat='{}{0:N0} руб.'}"
                                        Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
